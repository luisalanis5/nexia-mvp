rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: Is the user the owner of the path?
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper: Is the user an Admin?
    function isAdmin() {
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/creators/$(request.auth.uid)).data.role == 'admin';
    }

    // --- REGLAS PARA VERIFICACIÓN ---
    match /verification_requests/{userId}/{fileName} {
      allow write: if isOwner(userId) &&
                   request.resource.size < 5 * 1024 * 1024 &&
                   request.resource.contentType.matches('image/.*');
      allow read: if isOwner(userId) || isAdmin();
    }

    // --- REGLAS PARA CREATORES (Uploads de Módulos, Perfil, etc) ---
    match /creators/{userId}/{allPaths=**} {
      // Los creadores pueden gestionar sus propios archivos
      allow read: if true;
      allow create, update, delete: if isOwner(userId) &&
                                     request.resource.size < 5 * 1024 * 1024 &&
                                     (request.resource == null || request.resource.contentType.matches('image/.*'));
    }

    // --- REGLAS PARA FEEDBACK/ERRORES ---
    match /feedback/{userId}/{fileName} {
      allow write: if isOwner(userId) &&
                   request.resource.size < 5 * 1024 * 1024 &&
                   request.resource.contentType.matches('image/.*');
      allow read: if isAdmin();
    }

    // Regla por defecto: Denegar todo lo demás
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
