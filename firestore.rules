rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas universales y helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // 1. Colección users (Datos privados y de configuración)
    match /users/{userId} {
      // Nadie puede leer los datos privados excepto el dueño
      allow read: if isOwner(userId);
      // Solo el dueño puede crear o actualizar sus datos privados
      allow create, update, delete: if isOwner(userId);
    }

    // 2. Colección profiles (Datos públicos de la página del creador)
    match /profiles/{profileId} {
      // Cualquiera (incluso no registrados) puede leer perfiles (para rendering público)
      allow read: if true;
      
      // La escritura (crear, actualizar, borrar) está restringida al creador dueño
      allow create: if isOwner(profileId) && request.resource.data.uid == request.auth.uid;
      
      // Permitimos cambiar campos como theme (asegurando poder aplicar el #c2cdff), bio, etc.
      // Validación estricta: No pueden alterar su propio UID.
      allow update: if isOwner(profileId) && request.resource.data.uid == request.auth.uid;
      
      allow delete: if isOwner(profileId);

      // Subcolección de links (Públicos pero gestionados solo por el dueño)
      match /links/{linkId} {
        // Los visitantes necesitan leer los links activos para ir al destino
        allow read: if true;
        // Solo el creador del perfil padre puede manejar los enlaces
        allow create, update, delete: if isOwner(profileId);
      }
      
      // Subcolección de módulos adicionales (si existieran)
      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isOwner(profileId);
      }
    }
    
    // Legacy support (para el actual `creators` collection si aún se usa en el Dashboard de MVP)
    match /creators/{creatorId} {
       allow read, write: if isOwner(creatorId);
    }
  }
}
